name: Release

on:
  push:
    tags:
      # Semantic version tags only (e.g. 1.2.3)
      - "[0-9]+.[0-9]+.[0-9]+"
  workflow_dispatch:
    inputs:
      test_release:
        description: "Create a draft-only test release (never published)"
        required: false
        default: true
        type: boolean

# Least-privilege: only grant write where explicitly needed
permissions:
  contents: read

env:
  RUST_BACKTRACE: full
  CARGO_TERM_COLOR: always

jobs:
  # ─────────────────────────────────────────────
  # 1. Validate version and create a draft release
  # ─────────────────────────────────────────────
  create-release:
    name: Create Release
    runs-on: ubuntu-latest
    permissions:
      contents: write        # needed to create/upload the GitHub release
    outputs:
      version:      ${{ steps.version.outputs.version }}
      release_name: ${{ steps.version.outputs.release_name }}

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Determine version
        id: version
        run: |
          if [ "${{ github.event_name }}" = "push" ]; then
            VERSION="${{ github.ref_name }}"
            RELEASE_NAME="$VERSION"
          else
            VERSION=$(grep '^version' Cargo.toml | head -1 | cut -d'"' -f2)
            RELEASE_NAME="${VERSION}-test-$(date +%s)"
          fi
          echo "version=$VERSION"      >> "$GITHUB_OUTPUT"
          echo "release_name=$RELEASE_NAME" >> "$GITHUB_OUTPUT"
          echo "VERSION=$VERSION"      >> "$GITHUB_ENV"
          echo "RELEASE_NAME=$RELEASE_NAME" >> "$GITHUB_ENV"

      - name: Log version info
        run: |
          echo "Version:      $VERSION"
          echo "Release name: $RELEASE_NAME"
          echo "Trigger:      ${{ github.event_name }}"

      - name: Verify tag matches Cargo.toml (tag push only)
        if: github.event_name == 'push'
        run: |
          CARGO_VERSION=$(grep '^version' Cargo.toml | head -1 | cut -d'"' -f2)
          if [ "$CARGO_VERSION" != "$VERSION" ]; then
            echo "::error::Tag ($VERSION) does not match Cargo.toml version ($CARGO_VERSION)"
            exit 1
          fi
          echo "Version check passed: $VERSION"

      - name: Create draft GitHub release
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          gh release create "$RELEASE_NAME" \
            --draft \
            --title "Release $VERSION" \
            --notes "Automated release for $VERSION" \
            2>&1 | tee /tmp/release-create.log || {
              # Allow the job to continue if the release already exists
              grep -q "already exists" /tmp/release-create.log || exit 1
              echo "Release already exists — continuing."
            }

  # ─────────────────────────────────────────────
  # 2. Cross-platform builds
  # ─────────────────────────────────────────────
  build:
    name: Build · ${{ matrix.target }}
    needs: create-release
    runs-on: ${{ matrix.runner }}
    permissions:
      contents: read
    strategy:
      fail-fast: false
      matrix:
        include:
          # ── Linux ──────────────────────────────────────────────
          - target:   x86_64-unknown-linux-gnu
            runner:   ubuntu-latest
            archive:  tar.gz
            use_cross: false

          - target:   x86_64-unknown-linux-musl
            runner:   ubuntu-latest
            archive:  tar.gz
            use_cross: true          # cross handles musl sysroot cleanly

          - target:   i686-unknown-linux-gnu
            runner:   ubuntu-latest
            archive:  tar.gz
            use_cross: true

          - target:   i686-unknown-linux-musl
            runner:   ubuntu-latest
            archive:  tar.gz
            use_cross: true

          - target:   aarch64-unknown-linux-gnu
            runner:   ubuntu-latest
            archive:  tar.gz
            use_cross: true

          # ── macOS ──────────────────────────────────────────────
          - target:   x86_64-apple-darwin
            runner:   macos-latest
            archive:  tar.gz
            use_cross: false

          - target:   aarch64-apple-darwin
            runner:   macos-latest
            archive:  tar.gz
            use_cross: false

          # ── Windows ────────────────────────────────────────────
          - target:   x86_64-pc-windows-msvc
            runner:   windows-latest
            archive:  zip
            use_cross: false

          - target:   i686-pc-windows-msvc
            runner:   windows-latest
            archive:  zip
            use_cross: false

          - target:   x86_64-pc-windows-gnu
            runner:   windows-latest
            archive:  zip
            use_cross: false

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      # Pin to a specific hash for supply-chain safety
      - name: Install Rust toolchain
        uses: dtolnay/rust-toolchain@stable
        with:
          targets: ${{ matrix.target }}

      - name: Install cross
        if: matrix.use_cross == true
        uses: taiki-e/install-action@v2
        with:
          tool: cross

      # ── Caching ────────────────────────────────────────────────
      - name: Cache Cargo registry
        uses: actions/cache@v4
        with:
          path: |
            ~/.cargo/registry/index
            ~/.cargo/registry/cache
            ~/.cargo/git/db
          key: ${{ runner.os }}-cargo-${{ matrix.target }}-${{ hashFiles('**/Cargo.lock') }}
          restore-keys: |
            ${{ runner.os }}-cargo-${{ matrix.target }}-
            ${{ runner.os }}-cargo-

      - name: Cache build artifacts
        uses: actions/cache@v4
        with:
          path: target
          key: ${{ runner.os }}-build-${{ matrix.target }}-${{ hashFiles('**/Cargo.lock') }}
          restore-keys: |
            ${{ runner.os }}-build-${{ matrix.target }}-

      # ── Build ──────────────────────────────────────────────────
      - name: Build (cross)
        if: matrix.use_cross == true
        run: cross build --release --locked --target ${{ matrix.target }}

      - name: Build (cargo)
        if: matrix.use_cross == false
        run: cargo build --release --locked --target ${{ matrix.target }}

      # ── Strip debug info (Unix only) ───────────────────────────
      - name: Strip binary (Unix)
        if: runner.os != 'Windows'
        run: |
          BIN=$(find target/${{ matrix.target }}/release -maxdepth 1 -type f -perm /111 ! -name '*.d' | head -1)
          echo "Stripping: $BIN"
          strip "$BIN"

      # ── Package ────────────────────────────────────────────────
      - name: Package (tar.gz)
        if: matrix.archive == 'tar.gz'
        run: |
          DIST=dist/${{ matrix.target }}
          mkdir -p "$DIST"
          find target/${{ matrix.target }}/release -maxdepth 1 -type f -perm /111 ! -name '*.d' \
            -exec cp {} "$DIST/" \;
          [ -f README.md ] && cp README.md "$DIST/" || true
          cp LICENSE* "$DIST/" 2>/dev/null || true
          ARCHIVE="gitnav-${{ needs.create-release.outputs.version }}-${{ matrix.target }}.tar.gz"
          tar czf "$ARCHIVE" -C dist/${{ matrix.target }} .
          echo "ARCHIVE=$ARCHIVE" >> "$GITHUB_ENV"

      - name: Package (zip, Windows)
        if: matrix.archive == 'zip'
        shell: pwsh
        run: |
          $dist = "dist\${{ matrix.target }}"
          New-Item -ItemType Directory -Force -Path $dist | Out-Null
          $bin = Get-ChildItem "target\${{ matrix.target }}\release\*.exe" | Select-Object -First 1
          Copy-Item $bin.FullName $dist
          if (Test-Path README.md) { Copy-Item README.md $dist }
          Get-ChildItem LICENSE* -ErrorAction SilentlyContinue | Copy-Item -Destination $dist
          $archive = "gitnav-${{ needs.create-release.outputs.version }}-${{ matrix.target }}.zip"
          Compress-Archive -Path "$dist\*" -DestinationPath $archive -Force
          "ARCHIVE=$archive" | Out-File -FilePath $env:GITHUB_ENV -Append

      # ── Checksum ───────────────────────────────────────────────
      - name: Checksum (Unix)
        if: runner.os != 'Windows'
        run: |
          sha256sum "$ARCHIVE" > "${ARCHIVE}.sha256"
          echo "=== SHA256 ===" && cat "${ARCHIVE}.sha256"

      - name: Checksum (Windows)
        if: runner.os == 'Windows'
        shell: pwsh
        run: |
          $hash = (Get-FileHash -Algorithm SHA256 $env:ARCHIVE).Hash.ToLower()
          "$hash  $env:ARCHIVE" | Out-File -FilePath "$env:ARCHIVE.sha256" -Encoding UTF8 -NoNewline
          Get-Content "$env:ARCHIVE.sha256"

      # ── Upload to artifact store ───────────────────────────────
      - name: Upload artifacts
        uses: actions/upload-artifact@v4
        with:
          name: release-${{ matrix.target }}
          path: |
            gitnav-${{ needs.create-release.outputs.version }}-${{ matrix.target }}.*
          if-no-files-found: error
          retention-days: 5

  # ─────────────────────────────────────────────
  # 3. Publish all assets to the draft release
  # ─────────────────────────────────────────────
  publish:
    name: Publish Release
    runs-on: ubuntu-latest
    needs: [create-release, build]
    # Run even if some build legs failed so partial uploads still work
    if: always() && needs.create-release.result == 'success'
    permissions:
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Download all build artifacts
        uses: actions/download-artifact@v4
        with:
          path: artifacts/

      - name: Collect release files
        run: |
          mkdir -p release-artifacts
          find artifacts/ -type f \( -name "*.tar.gz" -o -name "*.zip" -o -name "*.sha256" \) \
            -exec cp {} release-artifacts/ \;
          echo "=== Files to publish ==="
          ls -lah release-artifacts/

      - name: Upload files to release
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          cd release-artifacts
          gh release upload "${{ needs.create-release.outputs.release_name }}" \
            $(ls) \
            --clobber

      # Only undraft on real tag pushes; test runs remain draft
      - name: Publish release (tag push only)
        if: github.event_name == 'push'
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          gh release edit "${{ needs.create-release.outputs.release_name }}" \
            --draft=false

  # ─────────────────────────────────────────────
  # 4. Update the Homebrew formula
  # ─────────────────────────────────────────────
  update-homebrew:
    name: Update Homebrew Formula
    runs-on: ubuntu-latest
    needs: [create-release, publish]
    # Only on real tag releases that were fully published
    if: >
      github.event_name == 'push' &&
      needs.publish.result == 'success' &&
      !contains(needs.create-release.outputs.version, 'test')
    permissions:
      contents: read

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Download checksums
        uses: actions/download-artifact@v4
        with:
          path: artifacts/

      - name: Extract checksums
        id: checksums
        run: |
          extract() {
            local dir="artifacts/release-${1}"
            local file="${dir}/gitnav-${{ needs.create-release.outputs.version }}-${1}.tar.gz.sha256"
            awk '{print $1}' "$file"
          }

          LINUX_GNU_SHA=$(extract  x86_64-unknown-linux-gnu)
          LINUX_ARM_SHA=$(extract  aarch64-unknown-linux-gnu)
          MACOS_X86_SHA=$(extract  x86_64-apple-darwin)
          MACOS_ARM_SHA=$(extract  aarch64-apple-darwin)

          echo "linux_gnu_sha=$LINUX_GNU_SHA" >> "$GITHUB_OUTPUT"
          echo "linux_arm_sha=$LINUX_ARM_SHA" >> "$GITHUB_OUTPUT"
          echo "macos_x86_sha=$MACOS_X86_SHA" >> "$GITHUB_OUTPUT"
          echo "macos_arm_sha=$MACOS_ARM_SHA" >> "$GITHUB_OUTPUT"

          printf "%-20s %s\n" "Linux x86_64:"  "$LINUX_GNU_SHA"
          printf "%-20s %s\n" "Linux aarch64:" "$LINUX_ARM_SHA"
          printf "%-20s %s\n" "macOS x86_64:"  "$MACOS_X86_SHA"
          printf "%-20s %s\n" "macOS aarch64:" "$MACOS_ARM_SHA"

      - name: Run Homebrew update script
        env:
          HOMEBREW_TOKEN:  ${{ secrets.HOMEBREW_GITHUB_TOKEN }}
          VERSION:         ${{ needs.create-release.outputs.version }}
          LINUX_GNU_SHA:   ${{ steps.checksums.outputs.linux_gnu_sha }}
          LINUX_ARM_SHA:   ${{ steps.checksums.outputs.linux_arm_sha }}
          MACOS_X86_SHA:   ${{ steps.checksums.outputs.macos_x86_sha }}
          MACOS_ARM_SHA:   ${{ steps.checksums.outputs.macos_arm_sha }}
        run: bash .github/scripts/update-homebrew.sh
